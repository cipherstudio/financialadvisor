---
import { getEmDashCollection, getEmDashEntry, getRequestContext } from "emdash";
import type { CacheHint, ContentEntry, MediaValue } from "emdash";
import { Image, PortableText } from "emdash/ui";
import type { Advisor, AdvisorPage as OurAdvisorsPageData } from "../../emdash-env";
import FadvisorStitchPage from "./FadvisorStitchPage.astro";
import { getLiveEntry } from "astro:content";

function mergeCacheHints(...hints: CacheHint[]): CacheHint {
	const tagSet = new Set<string>();
	let lastModified: Date | undefined;
	for (const h of hints) {
		for (const t of h.tags ?? []) tagSet.add(t);
		if (h.lastModified && (!lastModified || h.lastModified > lastModified)) {
			lastModified = h.lastModified;
		}
	}
	return { tags: tagSet.size ? [...tagSet] : undefined, lastModified };
}

const { entry: page, cacheHint: pageHint } = await getEmDashEntry("our_advisors_page", "main");

const collectionQuery = {
	orderBy: { published_at: "desc" as const },
	limit: 100,
};

const ctx = getRequestContext();
const inVisualEdit = ctx?.editMode === true;
/** ลิงก์ /?_preview=… จากแอดมิน (หน้า/รายการ) — getEmDashEntry ไม่ยก draft สำหรับ collection ลูก ต้องโหลด revision เอง */
const inSignedPreview = !!ctx?.preview;

const cacheHintParts: CacheHint[] = [pageHint];
let advisorRows: ContentEntry<Advisor>[];

/**
 * ดึง draft ตาม `draftRevisionId` บน row — ใช้ได้ทั้ง visual edit และ preview แบบ _preview= (ต่างกับ getEmDashEntry ที่ยก draft แค่ยาม editMode)
 */
async function resolveAdvisorRow(e: ContentEntry<Advisor>): Promise<ContentEntry<Advisor> | null> {
	const data = e.data as Advisor & { draftRevisionId?: string | null };
	const revId = data.draftRevisionId;
	if (typeof revId === "string" && revId.length > 0) {
		const { entry, error, cacheHint } = await getLiveEntry("_emdash", {
			type: "advisors",
			id: e.id,
			revisionId: revId,
		});
		if (cacheHint) cacheHintParts.push(cacheHint);
		if (!error && entry) {
			return entry as ContentEntry<Advisor>;
		}
	}
	if (inVisualEdit) {
		const { entry, cacheHint: rowHint } = await getEmDashEntry("advisors", e.id);
		if (rowHint) cacheHintParts.push(rowHint);
		return (entry as ContentEntry<Advisor> | null) ?? e;
	}
	return e;
}

if (inVisualEdit || inSignedPreview) {
	const { entries: published, cacheHint: publishedHint } = await getEmDashCollection("advisors", {
		...collectionQuery,
		status: "published",
	});
	const { entries: draftOnly, cacheHint: draftHint } = await getEmDashCollection("advisors", {
		...collectionQuery,
		status: "draft",
	});
	cacheHintParts.push(publishedHint, draftHint);
	const bySlug = new Map<string, ContentEntry<Advisor>>();
	for (const e of published) bySlug.set(e.id, e as ContentEntry<Advisor>);
	for (const e of draftOnly) {
		if (!bySlug.has(e.id)) bySlug.set(e.id, e as ContentEntry<Advisor>);
	}
	const combined = [...bySlug.values()];
	const overlaid: ContentEntry<Advisor>[] = [];
	for (const e of combined) {
		const entry = await resolveAdvisorRow(e);
		if (entry) overlaid.push(entry);
	}
	advisorRows = overlaid;
} else {
	const { entries, cacheHint: advisorsHint } = await getEmDashCollection("advisors", {
		...collectionQuery,
		status: "published",
	});
	cacheHintParts.push(advisorsHint);
	advisorRows = entries as ContentEntry<Advisor>[];
}

Astro.cache.set(mergeCacheHints(...cacheHintParts));

const p = page.data as unknown as OurAdvisorsPageData;
const pageTitle = p.page_title?.trim() || "ที่ปรึกษาทางการเงิน | FinancialAdvisorThailand";
const specHeading = p.specialties_section_heading?.trim() || "ความเชี่ยวชาญหลัก";

/** ตรงกับ `advisors` → ฟิลด์ `specialties` ใน schema — ค่าเก่าอื่นๆ ไม่อยู่ในฟอร์มแอดมินจะไม่โชว์ */
const ADVISOR_SPECIALTY_OPTIONS = [
	"Retirement Planning",
	"Tax Planning",
	"Wealth Management",
	"Insurance",
	"Mutual Funds",
	"Stocks",
	"Crypto",
	"Estate Planning",
	"Corporate Finance",
] as const;
const allowedSpecialties = new Set<string>(ADVISOR_SPECIALTY_OPTIONS);

function filterAdvisorySpecialties(list: string[] | undefined | null): string[] {
	if (!list?.length) return [];
	return list.filter((s) => typeof s === "string" && allowedSpecialties.has(s));
}

/** Slugs ที่ต้องการลำดับบนหน้า (รายการอื่นๆ ต่อท้ายตามเวลาเผยแพร่) */
const preferredAdvisorOrder = [
	"dr-witwat-lerp-phanit",
	"rinrada-sawatdet",
	"attapol-kijjamnong",
	"chonlada-panya-loet",
];

const advisors = [...advisorRows].sort((a, b) => {
	const ia = preferredAdvisorOrder.indexOf(a.id);
	const ib = preferredAdvisorOrder.indexOf(b.id);
	if (ia === -1 && ib === -1) return a.id.localeCompare(b.id);
	if (ia === -1) return 1;
	if (ib === -1) return -1;
	return ia - ib;
});

function parseCertLines(s: string | undefined): string[] {
	if (!s?.trim()) return [];
	return s
		.split(/[\n,]+/)
		.map((x) => x.trim())
		.filter((x) => x.length > 0);
}

type SocialRow = { platform?: string; url?: string };
function getSocial(list: unknown): SocialRow[] {
	if (!Array.isArray(list)) return [];
	return list.filter(
		(row): row is SocialRow => row != null && typeof row === "object",
	) as SocialRow[];
}

type TrustRow = {
	image?: { id?: string; src?: string; alt?: string; width?: number; height?: number; meta?: Record<string, unknown> } | string;
	label?: string;
	/** ข้อมูลเก่า: ใช้เป็น fallback ถ้ายังไม่อัปโหลดรูป */
	icon?: string;
};

/** รูปจาก EmDash มักมี id/storageKey โดยไม่มี src — ห้ามเช็คแค่ .src */
function hasMediaPayload(im: MediaValue | string | undefined | null): boolean {
	if (im == null) return false;
	if (typeof im === "string") return im.trim().length > 0;
	return Boolean(
		im.id ||
			im.src ||
			(im.meta as { storageKey?: string } | undefined)?.storageKey,
	);
}

function mediaForEmDashImage(im: MediaValue | string): MediaValue | string {
	if (typeof im === "string") return im;
	const isLocal = im.provider === "local" || im.provider == null;
	if (isLocal) {
		return { ...im, src: undefined };
	}
	return im;
}

function getTrustItems(raw: unknown): TrustRow[] {
	if (!Array.isArray(raw)) return [];
	return (raw as TrustRow[]).filter(
		(t) => t && (t.label || t.icon || hasMediaPayload(t.image as MediaValue | string | undefined)),
	);
}
---

<FadvisorStitchPage title={pageTitle} bodyClass="bg-surface text-on-surface antialiased">
	<main class="pt-20">
		<section class="bg-primary-container py-xxl relative overflow-hidden">
			<div class="absolute inset-0 opacity-10">
				<div class="absolute inset-0 bg-[radial-gradient(circle_at_50%_50%,#e9c349,transparent_70%)]" />
			</div>
			<div class="max-w-[1200px] mx-auto px-lg relative z-10 text-center">
				{
					p.hero_badge && (
						<span class="inline-block py-1 px-3 bg-secondary/20 text-secondary-fixed-dim rounded-full font-label-sm text-label-sm mb-md border border-secondary/30">
							{p.hero_badge}
						</span>
					)
				}
				{
					p.hero_title && (
						<h1 class="font-display text-display text-white mb-lg">{p.hero_title}</h1>
					)
				}
				{
					p.hero_subtitle && (
						<p class="font-body-lg text-body-lg text-on-primary-container max-w-2xl mx-auto">
							{p.hero_subtitle}
						</p>
					)
				}
			</div>
		</section>

		<section class="py-xxl max-w-[1200px] mx-auto px-lg">
			{
				(p.grid_section_title?.trim() || p.grid_section_intro?.trim()) && (
					<div class="mb-xl text-center max-w-3xl mx-auto">
						{
							p.grid_section_title?.trim() && (
								<h2 class="font-h2 text-h2 text-primary mb-sm">{p.grid_section_title.trim()}</h2>
							)
						}
						{
							p.grid_section_intro?.trim() && (
								<p class="font-body-md text-body-md text-on-surface-variant">
									{p.grid_section_intro.trim()}
								</p>
							)
						}
					</div>
				)
			}
			<div class="grid grid-cols-1 lg:grid-cols-2 gap-xl">
				{
					advisors.map((entry) => {
						const d = entry.data as Advisor;
						const certs = parseCertLines(d.certifications);
						const specs = filterAdvisorySpecialties(d.specialties);
						const socials = getSocial(d.social_links);
						return (
							<article class="bg-surface-container-lowest rounded-xl overflow-hidden shadow-[0_4px_6px_-1px_rgba(10,31,68,0.05),0_2px_4px_-1px_rgba(10,31,68,0.03)] border border-slate-100 flex flex-col border-t-4 border-t-secondary transition-all hover:shadow-[0_10px_15px_-3px_rgba(10,31,68,0.08)]">
								<div class="flex flex-col md:flex-row">
									<div class="md:w-[35%] shrink-0 min-w-0">
										<div class="advisor-card-photo relative aspect-[2/3] w-full overflow-hidden bg-slate-200">
											{hasMediaPayload(d.photo as MediaValue | undefined) ? (
												<Image
													class="h-full w-full min-h-0 object-cover"
													image={mediaForEmDashImage(d.photo as MediaValue)}
												/>
											) : (
												<div class="w-full h-full min-h-[200px] bg-slate-200 flex items-center justify-center">
													<span class="material-symbols-outlined text-5xl text-slate-400"
														>person</span
													>
												</div>
											)}
										</div>
									</div>
									<div class="md:w-[65%] p-lg flex flex-col">
										<div class="mb-md">
											<h2 class="font-h2 text-h2 text-primary mb-xs">{d.name}</h2>
											{d.role_title && (
												<p class="font-label-sm text-label-sm text-secondary font-semibold uppercase tracking-wider">
													{d.role_title}
												</p>
											)}
											{
												certs.length > 0 && (
													<div class="flex flex-wrap gap-2 mt-2">
														{certs.map((c) => (
															<span class="px-2 py-0.5 bg-primary-container text-white text-[11px] rounded font-bold">
																{c}
															</span>
														))}
													</div>
												)
											}
										</div>
										<div class="font-body-md text-body-md text-on-surface-variant leading-relaxed">
											{d.bio && d.bio.length > 0 ? (
												<PortableText value={d.bio} />
											) : null}
										</div>
									</div>
								</div>
								<div class="bg-slate-50 p-lg border-t border-slate-200">
									<p class="font-label-sm text-label-sm text-primary font-bold mb-3 uppercase">
										{specHeading}
									</p>
									{
										specs.length > 0 && (
											<div class="flex flex-wrap gap-2 mb-6">
												{specs.map((s) => (
													<span class="bg-white border border-slate-200 px-3 py-1 rounded-full text-xs text-on-surface-variant">
														{s}
													</span>
												))}
											</div>
										)
									}
									<div class="flex flex-col md:flex-row md:items-center justify-between gap-4 pt-4 border-t border-slate-200/60">
										<div class="flex flex-col gap-2">
											{
												d.email && (
													<div class="flex items-center gap-2 text-on-surface-variant text-sm">
														<span class="material-symbols-outlined text-sm">mail</span>
														<span>{d.email}</span>
													</div>
												)
											}
											{
												d.phone && (
													<div class="flex items-center gap-2 text-on-surface-variant text-sm">
														<span class="material-symbols-outlined text-sm">call</span>
														<span>{d.phone}</span>
													</div>
												)
											}
										</div>
										{
											socials.length > 0 && (
												<div class="flex gap-4">
													{socials.map((link) => {
														const u = (link.url || "#").trim();
														const pl = (link.platform || "").trim();
														const platformKey = pl.toLowerCase();
														return (
															<a
																class="text-on-primary-container hover:text-secondary transition-colors"
																href={u}
																target="_blank"
																rel="noopener noreferrer"
																title={pl}
															>
																{platformKey === "facebook" && (
																	<svg
																		class="w-5 h-5"
																		fill="currentColor"
																		viewBox="0 0 24 24"
																		aria-hidden="true"
																	>
																		<path d="M22 12c0-5.52-4.48-10-10-10S2 6.48 2 12c0 4.84 3.44 8.87 8 9.8V15H8v-3h2V9.5C10 7.57 11.57 6 13.5 6H16v3h-2c-.55 0-1 .45-1 1v2h3l-.5 3H13v6.8c4.56-.93 8-4.96 8-9.8z" />
																	</svg>
																)}
																{platformKey === "instagram" && (
																	<svg
																		class="w-5 h-5"
																		fill="currentColor"
																		viewBox="0 0 24 24"
																		aria-hidden="true"
																	>
																		<path d="M7.75 2h8.5A5.75 5.75 0 0 1 22 7.75v8.5A5.75 5.75 0 0 1 16.25 22h-8.5A5.75 5.75 0 0 1 2 16.25v-8.5A5.75 5.75 0 0 1 7.75 2m0 1.8A3.95 3.95 0 0 0 3.8 7.75v8.5a3.95 3.95 0 0 0 3.95 3.95h8.5a3.95 3.95 0 0 0 3.95-3.95v-8.5a3.95 3.95 0 0 0-3.95-3.95h-8.5zm8.9 1.35a1.2 1.2 0 1 1 0 2.4 1.2 1.2 0 0 1 0-2.4M12 7a5 5 0 1 1 0 10 5 5 0 0 1 0-10m0 1.8A3.2 3.2 0 1 0 12 15.2 3.2 3.2 0 0 0 12 8.8z" />
																	</svg>
																)}
																{platformKey === "x" && (
																	<svg
																		class="w-5 h-5"
																		fill="currentColor"
																		viewBox="0 0 24 24"
																		aria-hidden="true"
																	>
																		<path d="M18.9 2H22l-6.8 7.7L23.2 22h-6.3l-4.9-6.5L6.2 22H3l7.3-8.3L.8 2h6.4l4.4 5.9L18.9 2zm-1.1 18h1.7L6.3 3.9H4.5L17.8 20z" />
																	</svg>
																)}
																{platformKey === "tiktok" && (
																	<svg
																		class="w-5 h-5"
																		fill="currentColor"
																		viewBox="0 0 24 24"
																		aria-hidden="true"
																	>
																		<path d="M14.5 3c.3 1.8 1.3 3.2 3.1 3.9.9.3 1.7.4 2.4.4v3.2a8.6 8.6 0 0 1-3-.6v5.3c0 3.5-2.8 6.3-6.3 6.3S4.4 18.7 4.4 15.2c0-3.5 2.8-6.3 6.3-6.3.3 0 .7 0 1 .1v3.2a3 3 0 0 0-1-.2 3.2 3.2 0 1 0 3.2 3.2V3h.6z" />
																	</svg>
																)}
																{platformKey === "linkedin" && (
																	<svg
																		class="w-5 h-5"
																		fill="currentColor"
																		viewBox="0 0 24 24"
																		aria-hidden="true"
																	>
																		<path d="M19 3a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2h14m-.5 15.5v-5.3a2.7 2.7 0 0 0-2.7-2.7c-1.2 0-2.2 1-2.7 2.1V10h-2.6v8h2.6v-4.1c0-.6.4-1 1-1 .6 0 1 .4 1 1v4.1h2.7M9 10H6.4v8H9v-8M7.7 8.5a1.4 1.4 0 1 0 0-2.8 1.4 1.4 0 0 0 0 2.8z" />
																	</svg>
																)}
																{platformKey === "youtube" && (
																	<svg
																		class="w-5 h-5"
																		fill="currentColor"
																		viewBox="0 0 24 24"
																		aria-hidden="true"
																	>
																		<path d="M21.6 7.2a2.8 2.8 0 0 0-2-2c-1.8-.5-7.6-.5-7.6-.5s-5.8 0-7.6.5a2.8 2.8 0 0 0-2 2A29 29 0 0 0 2 12a29 29 0 0 0 .4 4.8 2.8 2.8 0 0 0 2 2c1.8.5 7.6.5 7.6.5s5.8 0 7.6-.5a2.8 2.8 0 0 0 2-2A29 29 0 0 0 22 12a29 29 0 0 0-.4-4.8zM10 15.5v-7l6 3.5-6 3.5z" />
																	</svg>
																)}
																{platformKey === "threads" && (
																	<svg
																		class="w-5 h-5"
																		fill="currentColor"
																		viewBox="0 0 16 16"
																		aria-hidden="true"
																	>
																		<path d="M6.321 6.016c-.27-.18-1.166-.802-1.166-.802.756-1.081 1.753-1.502 3.132-1.502.975 0 1.803.327 2.394.948s.928 1.509 1.005 2.644q.492.207.905.484c1.109.745 1.719 1.86 1.719 3.137 0 2.716-2.226 5.075-6.256 5.075C4.594 16 1 13.987 1 7.994 1 2.034 4.482 0 8.044 0 9.69 0 13.55.243 15 5.036l-1.36.353C12.516 1.974 10.163 1.43 8.006 1.43c-3.565 0-5.582 2.171-5.582 6.79 0 4.143 2.254 6.343 5.63 6.343 2.777 0 4.847-1.443 4.847-3.556 0-1.438-1.208-2.127-1.27-2.127-.236 1.234-.868 3.31-3.644 3.31-1.618 0-3.013-1.118-3.013-2.582 0-2.09 1.984-2.847 3.55-2.847.586 0 1.294.04 1.663.114 0-.637-.54-1.728-1.9-1.728-1.25 0-1.566.405-1.967.868ZM8.716 8.19c-2.04 0-2.304.87-2.304 1.416 0 .878 1.043 1.168 1.6 1.168 1.02 0 2.067-.282 2.232-2.423a6.2 6.2 0 0 0-1.528-.161" />
																	</svg>
																)}
																{platformKey === "pinterest" && (
																	<svg
																		class="w-5 h-5"
																		fill="currentColor"
																		viewBox="0 0 16 16"
																		aria-hidden="true"
																	>
																		<path d="M8 0a8 8 0 0 0-2.915 15.452c-.07-.633-.134-1.606.027-2.297.146-.625.938-3.977.938-3.977s-.239-.479-.239-1.187c0-1.113.645-1.943 1.448-1.943.682 0 1.012.512 1.012 1.127 0 .686-.437 1.712-.663 2.663-.188.796.4 1.446 1.185 1.446 1.422 0 2.515-1.5 2.515-3.664 0-1.915-1.377-3.254-3.342-3.254-2.276 0-3.612 1.707-3.612 3.471 0 .688.265 1.425.595 1.826a.24.24 0 0 1 .056.23c-.061.252-.196.796-.222.907-.035.146-.116.177-.268.107-1-.465-1.624-1.926-1.624-3.1 0-2.523 1.834-4.84 5.286-4.84 2.775 0 4.932 1.977 4.932 4.62 0 2.757-1.739 4.976-4.151 4.976-.811 0-1.573-.421-1.834-.919l-.498 1.902c-.181.695-.669 1.566-.995 2.097A8 8 0 1 0 8 0" />
																	</svg>
																)}
																{platformKey === "line" && (
																	<svg
																		class="w-5 h-5"
																		fill="currentColor"
																		viewBox="0 0 24 24"
																		aria-hidden="true"
																	>
																		<path d="M22 10.3c0-4.3-4.5-7.8-10-7.8S2 6 2 10.3c0 3.8 3.5 7 8.4 7.7.3.1.8.2 1 .5l-.1 1c0 .4-.2 1.1-.3 1.2s-.5.3 0 .4.4 0 .6-.1 1.1-.7 1.5-1.3 1.2-1.9 1.5-2.5c4.5-.9 7.4-4.1 7.4-7.4zm-12.9 3c0 .2-.1.4-.4.4h-1.6c-.3 0-.4-.2-.4-.4v-4c0-.2.1-.4.4-.4.2 0 .4.2.4.4v3.2h1.2c.3 0 .4.2.4.4zm2.1 0c0 .2-.1.4-.4.4h-.1c-.2 0-.4-.2-.4-.4v-4c0-.2.2-.4.4-.4.2 0 .4.2.4.4v4zm3.3 0c0 .1-.1.3-.2.4-.1.1-.2.2-.4.2-.2 0-.3-.1-.4-.2l-1.5-2.1v1.9c0 .2-.2.4-.4.4s-.4-.2-.4-.4v-4c0-.2.2-.4.4-.4.2 0 .3.1.4.2l1.5 2.1v-1.9c0-.2.2-.4.4-.4s.4.2.4.4v4zm2.6-1.2c0 .2-.2.4-.4.4h-1.2v.8h1.2c.2 0 .4.2.4.4s-.2.4-.4.4h-1.6c-.3 0-.4-.2-.4-.4v-4c0-.2.1-.4.4-.4h1.6c.2 0 .4.2.4.4s-.2.4-.4.4h-1.2v.8h1.2c.2 0 .4.2.4.4z" />
																	</svg>
																)}
																{platformKey !== "facebook" &&
																	platformKey !== "instagram" &&
																	platformKey !== "x" &&
																	platformKey !== "tiktok" &&
																	platformKey !== "linkedin" &&
																	platformKey !== "youtube" &&
																	platformKey !== "threads" &&
																	platformKey !== "pinterest" &&
																	platformKey !== "line" && (
																	<span class="text-xs underline">{pl || "Link"}</span>
																)}
															</a>
														);
													})}
												</div>
											)
										}
									</div>
								</div>
							</article>
						);
					})
				}
			</div>
		</section>

		{
			p.show_trust_section !== false && getTrustItems(p.trust_items).length > 0 && (
				<section class="bg-surface-container-low py-xl">
					<div class="max-w-[1200px] mx-auto px-lg">
						<div class="grid grid-cols-2 md:grid-cols-4 gap-lg items-center text-center">
							{getTrustItems(p.trust_items).map((t) => (
								<div class="flex flex-col items-center gap-2">
									<div class="h-16 w-16 shrink-0 flex items-center justify-center">
										{hasMediaPayload(t.image as MediaValue | string | undefined) && t.image != null ? (
											<Image
												class="max-h-16 w-auto max-w-full object-contain"
												image={mediaForEmDashImage(t.image as MediaValue | string)}
											/>
										) : t.icon ? (
											<span
												class="material-symbols-outlined text-secondary"
												style="font-size: 32px; font-variation-settings: 'FILL' 1;"
											>
												{t.icon}
											</span>
										) : (
											<span
												class="material-symbols-outlined text-slate-300"
												style="font-size: 32px"
												aria-hidden="true"
											>
												image
											</span>
										)}
									</div>
									<p class="font-label-sm text-label-sm text-on-surface-variant">
										{t.label}
									</p>
								</div>
							))}
						</div>
					</div>
				</section>
			)
		}
	</main>
	<style>
		/* EmDash ใส่ aspect-ratio ตามขนาดไฟล์ ทำให้รูปกลายเป็นสี่เหลี่ยมจัตุรัส — ยึดกรอบ 2:3 ของการ์ด */
		.advisor-card-photo :global(img) {
			width: 100% !important;
			height: 100% !important;
			object-fit: cover;
			aspect-ratio: unset !important;
			max-width: none !important;
		}
	</style>
</FadvisorStitchPage>
