---
import type { ContentEntry } from "emdash";
import type { Home, Testimonial } from "../../emdash-env";
import TestimonialCard from "./TestimonialCard.astro";

interface Props {
	page: { data: Home };
	featuredEntries: ContentEntry<Testimonial>[];
}

const { page, featuredEntries } = Astro.props;
const d = page.data;

const has = (s: string | undefined | null) => typeof s === "string" && s.trim() !== "";

const sectionOn = (b: unknown, defaultValue = true): boolean => {
	if (b === true || b === 1) return true;
	if (b === false || b === 0) return false;
	if (b == null) return defaultValue;
	if (typeof b === "string") {
		const t = b.trim().toLowerCase();
		if (t === "0" || t === "false") return false;
		if (t === "1" || t === "true") return true;
	}
	return defaultValue;
};

const sectionEnabled = sectionOn(d.testimonials_section_show, true);

const hasHeaderContent = has(d.testimonials_section_title) || has(d.testimonials_section_description);

const showSection = sectionEnabled && (featuredEntries.length > 0 || hasHeaderContent);

const sectionTitle = has(d.testimonials_section_title)
	? d.testimonials_section_title!.trim()
	: showSection
		? "เสียงสะท้อนจากลูกค้าของเรา"
		: "";

const sectionDescription = has(d.testimonials_section_description)
	? d.testimonials_section_description!.trim()
	: "";
---

{
	showSection && (
		<section class="py-xxl bg-surface-container-low overflow-hidden relative">
			<div class="max-w-7xl mx-auto px-8 relative z-10">
				<div class="text-center mb-xxl">
					{sectionTitle && (
						<h2 class="font-display text-4xl text-primary mb-md">{sectionTitle}</h2>
					)}
					{sectionDescription && (
						<p class="text-body-lg text-on-surface-variant max-w-2xl mx-auto">{sectionDescription}</p>
					)}
				</div>
				<div class="grid grid-cols-1 md:grid-cols-2 lg:grid-cols-3 gap-lg">
					{featuredEntries.length === 0 ? (
						<p class="text-on-surface-variant col-span-full text-center font-body-md">
							ยังไม่มีรีวิวที่เลือก “แสดงในหน้าแรก” — เปิดใช้ที่แก้ไขรายการใน Testimonials
						</p>
					) : (
						featuredEntries.map((entry) => <TestimonialCard entry={entry} />)
					)}
				</div>
			</div>
		</section>
	)
}
