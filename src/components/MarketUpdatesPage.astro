									</span>
								)
							}
							<span class="font-label-sm text-label-sm uppercase font-bold tracking-widest text-on-surface-variant leading-snug">
								{b.label}
							</span>
						</div>
					))}
				</div>
			)
		}
	</main>
</FadvisorStitchPage>

<script is:inline define:vars={{ slugByDate, calendarResetDate: currentDateKey }}>
	const trigger = document.getElementById("mu-cal-trigger");
	const input = document.getElementById("mu-cal-input");
	const emptyMsg = document.getElementById("mu-no-data-msg");
	if (trigger && input && input instanceof HTMLInputElement) {
		trigger.addEventListener("click", () => {
			emptyMsg?.classList.add("hidden");
			if (typeof input.showPicker === "function") {
				input.showPicker();
			} else {
				input.focus();
				input.click();
			}
		});
		input.addEventListener("change", () => {
			const v = input.value;
			const slug = slugByDate[v];
			if (slug) {
				emptyMsg?.classList.add("hidden");
				window.location.href = `/market-updates/${encodeURIComponent(slug)}`;
			} else if (v) {
				emptyMsg?.classList.remove("hidden");
				input.value = calendarResetDate;
			}
		});
	}
</script>

<style is:global>
	.market-summary-pt :global(p) {
		margin: 0;
	}
	.market-summary-pt :global(p + p) {
		margin-top: 0.5em;
	}
</style>
