								) : (
									<span
										class="text-xs font-bold text-primary-container uppercase tracking-widest opacity-70"
										{...(chromeEdit.losers_view_all_label ?? {})}
									>
										{losersViewLabel}
									</span>
								))
						}
					</div>
					<div class="divide-y divide-outline-variant/10">
						{
							losers.map((row) => (
								<div class="p-lg flex justify-between items-center hover:bg-surface-container-low transition-colors">
									<div>
										<p class="font-bold text-primary-container text-lg">{row.symbol ?? ""}</p>
										<p class="text-xs text-on-surface-variant font-medium">{row.company_name ?? ""}</p>
