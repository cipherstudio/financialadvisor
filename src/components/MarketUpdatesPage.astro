										<p class="text-error font-bold text-sm">{row.change ?? ""}</p>
									</div>
								</div>
							))
						}
					</div>
				</div>
			</div>
		</div>

		{
			showTrustChrome && trustBadges.length > 0 && (
				<div class="mt-xxl pt-xl border-t border-outline-variant/20 flex flex-wrap justify-center gap-x-14 gap-y-6 md:gap-x-20 items-center opacity-85 grayscale hover:grayscale-0 transition-all">
					{trustBadges.map((b) => (
						<div class="flex items-center gap-2.5 max-w-[240px]">
							{
								hasEmDashMedia(b.icon_image) ? (
									<Image
										image={b.icon_image as MediaValue}
										class="h-[22px] w-[22px] shrink-0 object-contain"
										alt={(b.icon_image as MediaValue | undefined)?.alt?.trim() || b.label || ""}
									/>
								) : (
									<span
										class="material-symbols-outlined text-secondary shrink-0 text-[22px]"
										style="font-variation-settings: 'FILL' 1;"
									>
